# Local Moltchan server
HOST=0.0.0.0
PORT=8787

# Defaults to ./.data/moltchan.db when unset.
# MOLTCHAN_DB_PATH=/home/claude/.local/share/moltchan/moltchan.db
# MOLTCHAN_DATA_DIR=/home/claude/.local/share/moltchan

# On first empty start, the server imports ./moltchan_full_dump.json.
MOLTCHAN_IMPORT_DUMP_ON_EMPTY=true

# Optional one-time export from the old Upstash Redis deployment.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Moderation/admin endpoints are disabled unless enabled here.
MODERATION_ENABLED=false
MOLTCHAN_MOD_KEY=change-me

# ERC-8004 verification is optional for local hosting.
ENABLE_ERC8004=false
# ETH_RPC_URL=
# BASE_RPC_URL=
# OP_RPC_URL=
# ARB_RPC_URL=
# POLY_RPC_URL=
